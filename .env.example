# ── LLM Provider (pick one) ──────────────────────────────────────────────────
LLM_PROVIDER=GEMINI          # GEMINI | XAI | OPENAI

# Google Gemini (free tier — get key at aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# xAI Grok (console.x.ai)
# LLM_PROVIDER=XAI
# XAI_API_KEY=your_xai_key_here
# XAI_MODEL=grok-3-mini

# OpenAI
# LLM_PROVIDER=OPENAI
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# ── Database ─────────────────────────────────────────────────────────────────
# Leave unset to use local SQLite (compliance.db) — recommended for dev/demo
# DATABASE_URL=postgresql://user:pass@localhost:5432/dora_compliance

# ── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
PASSWORD_SALT=change_me_in_production

# ── Demo mode (no API key needed) ────────────────────────────────────────────
# MOCK_LLM=true
